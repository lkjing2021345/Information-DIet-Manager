{
  "manifest_version": 3,
  "name": "Information Diet Collector",
  "version": "0.1",
  "description": "Collect browsing information for analysis",

  "permissions": [
    "tabs",
    "scripting",
    "activeTab"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  }
}